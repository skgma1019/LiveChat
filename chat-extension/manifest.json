{
  "manifest_version": 3,
  "name": "LiveChat",
  "version": "1.0.0",
  "description": "LiveChat 실시간 채팅 확장",
  "permissions": ["storage"],
  "host_permissions": ["https://livechat-u2jk.onrender.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
